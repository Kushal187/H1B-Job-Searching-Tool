# Supabase/Postgres backend (optional; if unset, app uses local SQLite)
DATABASE_URL=postgresql://postgres:dtiLZoC6Waarr4Fi@db.daugalaljnzvhtxfcsmj.supabase.co:5432/postgres

# SEC requires a descriptive User-Agent with contact details
# Only needed for: python pipeline.py collect
SEC_USER_AGENT=H1BJobTool your-email@example.com

# Admin portal protection:
# 1) Set both ADMIN_USERNAME and ADMIN_PASSWORD to require Basic Auth on
#    /admin and /api/admin/*.
# 2) Set ADMIN_DISABLED=true to disable admin routes entirely.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_DISABLED=false

# Extension + API cross-origin access (comma separated, "*" for dev)
CORS_ALLOW_ORIGINS=*

# Resume tailoring model routing and budgets
BEDROCK_REGION=us-east-1
RESUME_ENABLE_BEDROCK=true
# Required for models that need profile throughput (e.g., many Claude Sonnet IDs)
RESUME_BEDROCK_INFERENCE_PROFILE_ID=
RESUME_PARSER_MODEL=openai.gpt-oss-20b-1:0
RESUME_REWRITER_MODEL=anthropic.claude-3-7-sonnet-20250219-v1:0
RESUME_VALIDATOR_MODEL=openai.gpt-oss-20b-1:0
RESUME_MAX_MODEL_TOKENS=1200
RESUME_MAX_JD_CHARS=20000
RESUME_DAILY_TOKEN_BUDGET=600000
RESUME_REQUEST_TOKEN_BUDGET=70000

# Optional absolute path to your own LaTeX template
RESUME_LATEX_TEMPLATE_PATH=/Users/kushalpendekanti/Documents/Coding-Fun/job-search-tool/kushal-resume-template.tex

# Tectonic binary path (defaults to \"tectonic\")
TECTONIC_BIN=tectonic

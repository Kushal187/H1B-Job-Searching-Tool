{
  "manifest_version": 3,
  "name": "JD Resume Autotailor",
  "version": "0.1.0",
  "description": "Capture job descriptions from the current tab and generate tailored resumes.",
  "permissions": [
    "activeTab",
    "downloads",
    "scripting",
    "sidePanel",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:8000/*",
    "https://*.vercel.app/*",
    "https://boards-api.greenhouse.io/*",
    "https://api.lever.co/*",
    "https://api.ashbyhq.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Tailor Resume",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
